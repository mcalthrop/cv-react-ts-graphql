{
  "name": "cv-react-ts-graphql",
  "version": "1.0.0",
  "description": "Online CV for Matt Calthrop, using React, TypeScript & GraphQL",
  "type": "module",
  "repository": "git@github.com:mcalthrop/cv-react-ts-graphql.git",
  "author": "Matt Calthrop <matt@calthrop.com>",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": "24.x",
    "pnpm": "10.32.1",
    "npm": "please-use-pnpm",
    "yarn": "please-use-pnpm"
  },
  "scripts": {
    "build": "pnpm graphql:types && next build",
    "compile": "pnpm graphql:types && tsc",
    "check": "biome check",
    "check:fix": "biome check --write",
    "graphql:types": "graphql-codegen --verbose && scripts/fix-generated-graphql-types.sh",
    "knip": "pnpm graphql:types && knip",
    "prepare": "husky",
    "start:dev": "pnpm graphql:types && next dev",
    "start:prod": "pnpm build && next start",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@apollo/client": "4.1.6",
    "@apollo/client-integration-nextjs": "0.14.4",
    "@chakra-ui/react": "3.34.0",
    "@emotion/react": "11.14.0",
    "@vercel/analytics": "2.0.1",
    "@vercel/speed-insights": "2.0.0",
    "graphql": "16.13.2",
    "next": "16.2.1",
    "next-themes": "0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "5.6.0",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@graphql-codegen/cli": "6.2.1",
    "@graphql-codegen/client-preset": "5.2.4",
    "@graphql-typed-document-node/core": "3.2.0",
    "@next/bundle-analyzer": "16.2.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.2",
    "@vitest/ui": "4.1.2",
    "happy-dom": "20.8.9",
    "husky": "9.1.7",
    "knip": "6.3.0",
    "msw": "2.12.14",
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  }
}
